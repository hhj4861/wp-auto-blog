# Google Trends (no API key needed for pytrends)

# Hacker News (no API key needed)

# Reddit API
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=wp-auto-blog/1.0

# AI APIs (at least one required)
OPENAI_API_KEY=your_openai_key
GOOGLE_AI_API_KEY=your_google_ai_key

# Unsplash API
UNSPLASH_ACCESS_KEY=your_unsplash_key

# Pexels API (backup)
PEXELS_API_KEY=your_pexels_key

# WordPress
WP_URL=https://your-blog.com
WP_USERNAME=your_username
WP_APP_PASSWORD=your_application_password

# Notification
NOTIFICATION_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# Optional: Slack
SLACK_WEBHOOK_URL=

# ── 제휴(Affiliate) 링크 ─────────────────────────────────
# 각 프로그램 승인 후 발급받은 쿼리 조각을 그대로 넣으세요.
# 비워두면 순수 검색 링크로 동작(수익 0, 오류 없음).
# Amazon Associates(US): 예) tag=yourid-20
AFFILIATE_AMAZON=
# YesStyle 제휴: 예) ref=xxxxx
AFFILIATE_YESSTYLE=
# Musinsa Global 제휴
AFFILIATE_MUSINSA=
# 올리브영 Global 제휴
AFFILIATE_OLIVE_YOUNG=
